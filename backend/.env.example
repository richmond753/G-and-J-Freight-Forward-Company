# ─────────────────────────────────────────────
#  G and J Freight Services – Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# CORS – comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://gandjfreightservices.com

# Email (SMTP) – used by Nodemailer to send contact-form submissions
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Where contact-form emails are delivered
CONTACT_RECEIVER=info@gandjfreightservices.com

# Rate-limiting (requests per window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
